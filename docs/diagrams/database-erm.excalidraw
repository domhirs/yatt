    {
      "id": "employee-columns-text",
      "type": "text",
      "x": 215,
      "y": 134,
      "width": 370,
      "height": 316,
      "text": "PK  id           UUID           NOT NULL\n    first_name   VARCHAR(100)   NOT NULL\n    last_name    VARCHAR(100)   NOT NULL\nUQ  email        VARCHAR(255)   NOT NULL\n    department   VARCHAR(100)   NOT NULL\n    role         VARCHAR(100)   NOT NULL\n    hire_date    DATE           NOT NULL\nFK  manager_id   UUID           NULL\nCK  status       VARCHAR(20)    NOT NULL\n    version      BIGINT         NOT NULL\n    created_at   TIMESTAMPTZ    NOT NULL\n    updated_at   TIMESTAMPTZ    NOT NULL",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",

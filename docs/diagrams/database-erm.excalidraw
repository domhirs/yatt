    {
      "id": "constraints-body",
      "type": "text",
      "x": 200,
      "y": 512,
      "width": 500,
      "height": 100,
      "text": "PK  employee_pkey            PRIMARY KEY (id)\nUQ  uq_employee_email        UNIQUE (email)\nFK  employee_manager_id_fkey  REFERENCES employee(id)\nCK  chk_employee_status       CHECK (status IN ('ACTIVE','INACTIVE'))",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
